# AWS credentials — these stay in .env to bootstrap the Secrets Manager connection
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# Used for AWS Secrets Manager and DynamoDB clients.
REGION_NAME=eu-west-2

# All other settings are stored in AWS Secrets Manager under:
# Secret name: dev/ds-may26/LeaseSummariser
#
# Required secret keys:
#   AZURE_OPENAI_API_KEY
#   AZURE_OPENAI_ENDPOINT
#   AZURE_OPENAI_API_VERSION
#   AZURE_OPENAI_DEPLOYMENT
#   AZURE_OPENAI_EMBEDDING_DEPLOYMENT
#   AZURE_OPENAI_GENERATION_API
#   S3_BUCKET_NAME
#   S3_PREFIX
#   S3_PDF_FILE_NAME
#   PDF_SOURCE_DIR
#   LANGFUSE_SECRET_KEY
#   LANGFUSE_PUBLIC_KEY
#   LANGFUSE_BASE_URL
#   FASTAPI_BASE_URL
#   CHROMA_PERSIST_DIR
#   CHROMA_COLLECTION_NAME
#   CHAT_HISTORY_TABLE_NAME
